<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register | Aura AI Assistant</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include("partials/navbar") %>

    <section class="container py-5">

        <div class="row align-items-center justify-content-center g-5 min-vh-75">

            <!-- Left Side -->

            <div class="col-lg-6 text-center">

                <img
                    src="/images/robot.png"
                    class="img-fluid register-image"
                    alt="Aura AI"
                    style="max-height:450px;">

                <h2 class="mt-4 fw-bold">
                    Join Aura AI 🚀
                </h2>

                <p class="text-secondary">
                    Create your free account and start chatting with your intelligent AI assistant.
                </p>

            </div>

            <!-- Right Side -->

            <div class="col-lg-5">

                <div class="card shadow-lg border-0 register-card">

                    <div class="card-body p-5">

                        <h2 class="text-center mb-4 fw-bold">
                            📝 Create Account
                        </h2>

                        <form action="/register" method="POST">

                            <div class="mb-3">

                                <label class="form-label">
                                    Full Name
                                </label>

                                <input
                                    type="text"
                                    name="name"
                                    class="form-control"
                                    placeholder="Enter your full name"
                                    required>

                            </div>

                            <div class="mb-3">

                                <label class="form-label">
                                    Email Address
                                </label>

                                <input
                                    type="email"
                                    name="email"
                                    class="form-control"
                                    placeholder="Enter your email"
                                    required>

                            </div>

                            <div class="mb-4">

                                <label class="form-label">
                                    Password
                                </label>

                                <input
                                    type="password"
                                    name="password"
                                    class="form-control"
                                    placeholder="Create a secure password"
                                    required>

                            </div>

                            <button
                                type="submit"
                                class="btn btn-success w-100 py-2">

                                Create Account

                            </button>

                        </form>

                        <hr class="my-4">

                        <p class="text-center mb-0">

                            Already have an account?

                            <a href="/login" class="text-decoration-none fw-semibold">
                                Login
                            </a>

                        </p>

                    </div>

                </div>

            </div>

        </div>

    </section>

    <%- include("partials/footer") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- GSAP -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

<script>
window.onload = () => {

    // Navbar
    gsap.from(".navbar", {
        y: -40,
        opacity: 0,
        duration: 0.6
    });

    // Left section
    gsap.from(".hero-content, .login-image", {
        x: -40,
        opacity: 0,
        duration: 0.8
    });

    // Cards
    gsap.from(".card", {
        y: 30,
        opacity: 0,
        duration: 0.8
    });

    gsap.to(".hero-image, .login-image", {
    y: -10,
    duration: 2,
    repeat: -1,
    yoyo: true,
    ease: "power1.inOut"
});

};
</script>

</body>

</html>