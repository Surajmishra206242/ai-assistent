<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aura AI Assistant</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include("partials/navbar") %>

    <!-- Hero Section -->
    <section class="container hero-section py-5">

        <div class="row align-items-center">

            <div class="col-lg-6 hero-content">

                <span class="badge bg-primary px-3 py-2 mb-3">
                    🚀 Powered by OpenRouter AI
                </span>

                <h1 class="display-3 fw-bold mb-4">
                    Meet <span class="text-primary">Aura AI</span><br>
                    Your Intelligent Assistant
                </h1>

                <p class="lead text-secondary mb-4">
                    Chat naturally, get instant AI-powered answers, save your conversations,
                    and continue where you left off.
                </p>

                <% if(user){ %>

                    <a href="/chat" class="btn btn-primary btn-lg me-3">
                        💬 Start Chatting
                    </a>

                <% } else { %>

                    <a href="/register" class="btn btn-primary btn-lg me-3">
                        🚀 Get Started
                    </a>

                    <a href="/login" class="btn btn-outline-light btn-lg">
                        Login
                    </a>

                <% } %>

            </div>

            <div class="col-lg-6 text-center">

                <img
                    src="/images/robot.png"
                    class="img-fluid hero-image"
                    alt="Aura AI"
                    style="max-height:500px;">

            </div>

        </div>

    </section>

    <!-- Features -->

    <section class="container py-5">

        <div class="text-center mb-5">

            <h2 class="fw-bold">
                Why Choose Aura AI?
            </h2>

            <p class="text-secondary">
                Fast, intelligent and beautifully designed.
            </p>

        </div>

        <div class="row g-4">

            <div class="col-md-4">

                <div class="card feature-card h-100">

                    <div class="card-body text-center p-4">

                        <div class="display-3 mb-3">
                            💬
                        </div>

                        <h4>Smart Chat</h4>

                        <p class="text-secondary">
                            Ask anything and receive intelligent AI-powered responses instantly.
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card feature-card h-100">

                    <div class="card-body text-center p-4">

                        <div class="display-3 mb-3">
                            📚
                        </div>

                        <h4>Chat History</h4>

                        <p class="text-secondary">
                            Every conversation is automatically saved to your account.
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card feature-card h-100">

                    <div class="card-body text-center p-4">

                        <div class="display-3 mb-3">
                            ⚡
                        </div>

                        <h4>Lightning Fast</h4>

                        <p class="text-secondary">
                            Powered by OpenRouter AI for quick and reliable answers.
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </section>

    <!-- CTA -->

    <section class="container py-5">

        <div class="card cta-card shadow-lg text-center p-5">

            <h2 class="mb-3">
                Ready to experience AI?
            </h2>

            <p class="text-secondary mb-4">
                Start chatting with Aura AI today.
            </p>

            <% if(user){ %>

                <a href="/chat" class="btn btn-primary btn-lg">
                    Open Chat
                </a>

            <% } else { %>

                <a href="/register" class="btn btn-primary btn-lg">
                    Create Free Account
                </a>

            <% } %>

        </div>

    </section>

    <%- include("partials/footer") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

 <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

<script>
window.addEventListener("load", () => {

    gsap.from("body", {
        opacity: 0,
        duration: 1
    });

});
</script>
</body>

</html>