<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aura AI Assistant</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include("partials/navbar") %>

    <div class="container-fluid py-3">

        <div class="row g-3">

            <!-- Sidebar -->
            <div class="col-lg-3 col-md-4">

                <div class="card h-100 p-3">

                    <form action="/chat/new" method="POST">
                        <button class="btn btn-primary w-100 mb-4">
                            ✨ New Chat
                        </button>
                    </form>

                    <h5 class="mb-3">Your Chats</h5>

                    <div class="list-group">

                        <% if(chats.length === 0){ %>

                            <p class="text-white-50">
                                No chats yet.
                            </p>

                        <% } %>

                        <% chats.forEach(chat => { %>

                            <a
                                href="/chat/<%= chat._id %>"
                                class="list-group-item list-group-item-action <%= activeChat == chat._id.toString() ? 'active' : '' %>">

                                <%= chat.title %>

                            </a>

                        <% }) %>

                    </div>

                </div>

            </div>

            <!-- Chat -->
            <div class="col-lg-9 col-md-8">

                <div class="card h-100 d-flex flex-column">

                    <!-- Chat Box -->

                    <div id="chat-box" class="flex-grow-1 p-4">

                        <% if(messages.length === 0){ %>

                            <div class="text-center mt-5">

                                <h2 class="mb-3">
                                    👋 Welcome, <%= user.name %>
                                </h2>

                                <p class="text-white-50">
                                    Ask anything and start chatting with your AI Assistant.
                                </p>

                            </div>

                        <% } %>

                        <% messages.forEach(message => { %>

                            <% if(message.role === "user"){ %>

                                <div class="user-message">

                                    <div>
                                        <%= message.content %>
                                    </div>

                                </div>

                            <% } else { %>

                                <div class="ai-message">

                                    <div class="markdown-body">
                                        <%= message.content %>
                                    </div>

                                </div>

                            <% } %>

                        <% }) %>

                    </div>

                    <!-- Input -->

                    <% if(activeChat){ %>

                    <div class="p-3">

                        <form
                            id="chat-form"
                            action="/chat/<%= activeChat %>/message"
                            method="POST">

                            <div class="input-group">

                                <input
                                    type="text"
                                    name="prompt"
                                    class="form-control"
                                    placeholder="Ask me anything..."
                                    autocomplete="off"
                                    required>

                                <button
                                    class="btn btn-primary px-4"
                                    type="submit">

                                    Send

                                </button>

                            </div>

                        </form>

                    </div>

                    <% } %>

                </div>

            </div>

        </div>

    </div>

    <%- include("partials/footer") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <script src="/js/chat.js"></script>

    <script src="/js/gsap.js"></script>

</body>

</html>