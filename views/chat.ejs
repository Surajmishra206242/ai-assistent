<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aura AI Assistant</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/chat.css">
</head>

<body>

    <%- include("partials/navbar") %>

    <div class="container-fluid py-3">

        <div class="row g-3">

            <!-- Sidebar -->
            <div class="col-lg-3">

                <div class="card sidebar-card h-100">

                    <div class="card-body d-flex flex-column">

                        <form action="/chat/new" method="POST">
                            <button class="btn btn-primary w-100 mb-4">
                                ✨ New Chat
                            </button>
                        </form>

                        <h5 class="mb-3 text-white">
                            Your Chats
                        </h5>

                        <div class="list-group flex-grow-1">

                            <% if(chats.length===0){ %>

                                <p class="text-secondary">
                                    No chats yet.
                                </p>

                            <% } %>

                            <% chats.forEach(chat=>{ %>

                                <a
                                    href="/chat/<%= chat._id %>"
                                    class="list-group-item list-group-item-action <%= activeChat==chat._id.toString() ? 'active' : '' %>">

                                    <%= chat.title %>

                                </a>

                            <% }) %>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Chat Area -->

            <div class="col-lg-9">

                <div class="card chat-card">

                    <!-- Messages -->

                    <div id="chat-box" class="chat-box">

                        <% if(messages.length===0){ %>

                            <div class="welcome">

                                <h2>
                                    👋 Welcome,
                                    <%= user.name %>
                                </h2>

                                <p>
                                    Ask Aura AI anything to get started.
                                </p>

                            </div>

                        <% } %>

                        <% messages.forEach(message=>{ %>

                            <% if(message.role==="user"){ %>

                                <div class="user-message">

                                    <div class="message-content">

                                        <%= message.content %>

                                    </div>

                                </div>

                            <% } else { %>

                                <div class="ai-message">

                                    <div class="message-content markdown-body">

                                        <%= message.content %>

                                    </div>

                                </div>

                            <% } %>

                        <% }) %>

                    </div>

                    <!-- Input -->

                    <% if(activeChat){ %>

                    <div class="chat-input">

                        <form
                            id="chat-form"
                            action="/chat/<%= activeChat %>/message"
                            method="POST">

                            <div class="input-group">

                                <input
                                    type="text"
                                    class="form-control"
                                    name="prompt"
                                    placeholder="Message Aura AI..."
                                    autocomplete="off"
                                    required>

                                <button
                                    class="btn btn-primary"
                                    type="submit">

                                    Send

                                </button>

                            </div>

                        </form>

                    </div>

                    <% } %>

                </div>

            </div>

        </div>

    </div>

    <%- include("partials/footer") %>

    <!-- Bootstrap -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Marked -->

    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <!-- GSAP -->

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

    <!-- Chat JS -->

    <script src="/js/chat.js"></script>

    <script>

        // Convert Markdown

        document.querySelectorAll(".markdown-body").forEach(el => {

            el.innerHTML = marked.parse(el.innerHTML);

        });

        // Auto Scroll

        const chatBox = document.getElementById("chat-box");

        chatBox.scrollTop = chatBox.scrollHeight;

        // Minimal GSAP

        window.onload = () => {

            gsap.from(".navbar",{
                y:-25,
                opacity:0,
                duration:.5
            });

            gsap.from(".sidebar-card",{
                x:-20,
                opacity:0,
                duration:.6
            });

            gsap.from(".chat-card",{
                y:20,
                opacity:0,
                duration:.6
            });

        };

    </script>

</body>

</html>